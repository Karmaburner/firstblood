---
import '../styles/global.css'

const nav = [
  { href: '/',        label: 'Forside' },
  { href: '/galleri', label: 'Galleri' },
  { href: '/om',      label: 'Om' },
  { href: '/kontakt', label: 'Kontakt' },
]
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Meny | First Blood Tattoo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Teppe bakgrunn -->
    <div id="teppe-bg"></div>

    <!-- X knapp -->
    <a href="javascript:history.back()" id="close-btn" aria-label="Lukk">
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </a>

    <main>
      <div id="logo-col">
        <div class="inline-block" style="position: relative;">
          <img src="/images/logo.png" alt="" id="meny-skull-img" class="absolute inset-0 w-full h-full object-contain pointer-events-none" />
          <img src="/images/first%20blood%20tekst.png" alt="First Blood" id="meny-fb-img" class="relative w-auto drop-shadow-2xl" />
        </div>
      </div>

      <nav id="nav-col">
        {nav.map(({ href, label }) => (
          <a href={href} class="nav-link">{label}</a>
        ))}
      </nav>
    </main>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background-color: #1c1c1c;
    color: #F0EBE0;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  #teppe-bg {
    position: fixed;
    inset: 0;
    background-image: url('/images/teppe.avif');
    background-repeat: repeat;
    background-size: 600px;
    mix-blend-mode: overlay;
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }

  #close-btn {
    position: fixed;
    top: 2rem;
    right: 2.5rem;
    color: #F0EBE0;
    z-index: 10;
    opacity: 0.7;
    transition: opacity 0.2s;
    text-decoration: none;
  }
  #close-btn:hover { opacity: 1; }

  main {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(3rem, 10vw, 10rem);
    padding: 4rem 2rem;
  }

  #logo-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  #meny-fb-img   { height: 20rem; transform: translateY(-83px); }
  #meny-skull-img { transform: translate(50px, 32px); }

  #nav-col {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-link {
    font-family: 'Anton', sans-serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #F0EBE0;
    text-decoration: none;
    line-height: 1;
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: #C41E3A;
  }
</style>
