---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Kontakt">
  <section class="max-w-4xl mx-auto px-4 md:px-6 py-10 md:py-16">
    <h1 class="font-bold text-center mb-3" style="color: var(--text);">Kontakt</h1>
    <p class="text-center mb-4" style="color: var(--muted);">Ring eller send melding for timebestilling og spørsmål.</p>
    <p class="text-center mb-10 md:mb-14">
      <span style="font-family: 'Anton', sans-serif; font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent);">Gratis konsultasjon</span>
      <span style="color: var(--muted); font-size: 0.9rem;"> — ta kontakt så finner vi det rette for deg.</span>
    </p>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <!-- Kontaktinfo -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold mb-4" style="color: var(--text); font-family: 'Cormorant Garamond', serif;">Kontaktinformasjon</h2>

        <a href="tel:47315959" class="flex items-center gap-4 p-4 rounded-xl border transition-colors group hover:opacity-80" style="background-color: var(--bg-secondary); border-color: var(--border);">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #2a2a2a; color: var(--text);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11 19.79 19.79 0 0 1 1.62 2.38a2 2 0 0 1 1.79-2.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.29 6.29l.46-.46a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-wide" style="color: var(--muted);">Telefon</p>
            <p class="font-medium" style="color: var(--text);">47 31 59 59</p>
          </div>
        </a>

        <div class="flex items-center gap-4 p-4 rounded-xl border" style="background-color: var(--bg-secondary); border-color: var(--border);">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #2a2a2a; color: var(--text);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-wide" style="color: var(--muted);">Adresse</p>
            <p class="font-medium" style="color: var(--text);">Langgata 1B, 4306 Sandnes</p>
          </div>
        </div>

        <div class="flex items-center gap-4 p-4 rounded-xl border" style="background-color: var(--bg-secondary); border-color: var(--border);">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #2a2a2a; color: var(--text);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-wide" style="color: var(--muted);">Åpningstider</p>
            <p class="font-medium" style="color: var(--text);">Man–lør kl. 10:00</p>
            <p class="text-xs mt-0.5" style="color: var(--muted);">Etter avtale</p>
          </div>
        </div>

        <a href="https://www.facebook.com/firstbloodtattoo" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-xl border transition-colors group hover:opacity-80" style="background-color: var(--bg-secondary); border-color: var(--border);">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #2a2a2a; color: var(--text);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-wide" style="color: var(--muted);">Facebook</p>
            <p class="font-medium" style="color: var(--text);">firstbloodtattoo</p>
          </div>
        </a>

        <a href="https://www.instagram.com/megatrond9/" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-xl border transition-colors group hover:opacity-80" style="background-color: var(--bg-secondary); border-color: var(--border);">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #2a2a2a; color: var(--text);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-wide" style="color: var(--muted);">Instagram</p>
            <p class="font-medium" style="color: var(--text);">@megatrond9</p>
          </div>
        </a>
      </div>

      <!-- Kontaktskjema -->
      <div>
        <h2 class="text-xl font-semibold mb-6" style="color: var(--text); font-family: 'Cormorant Garamond', serif;">Send en melding</h2>
        <form class="space-y-4" id="contact-form" action="https://formspree.io/f/XXXXXXXX" method="POST">
          <div>
            <label for="name" class="block text-sm font-medium mb-1" style="color: var(--muted);">Navn</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-2.5 rounded-lg border focus:outline-none text-sm"
              style="background-color: var(--bg-secondary); border-color: var(--border); color: var(--text);"
              placeholder="Ditt navn"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1" style="color: var(--muted);">Telefon</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-2.5 rounded-lg border focus:outline-none text-sm"
              style="background-color: var(--bg-secondary); border-color: var(--border); color: var(--text);"
              placeholder="Ditt telefonnummer"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-1" style="color: var(--muted);">Melding</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2.5 rounded-lg border focus:outline-none text-sm resize-none"
              style="background-color: var(--bg-secondary); border-color: var(--border); color: var(--text);"
              placeholder="Fortell litt om hva du ønsker å tatovere..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2 text-white py-3 rounded-full font-medium hover:opacity-85 transition-opacity"
            style="background-color: var(--accent);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send melding
          </button>
          <p id="form-status" class="text-center text-sm hidden" style="color: var(--muted);"></p>
        </form>
      </div>
    </div>
  </section>
</Layout>
