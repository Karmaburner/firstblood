---
import Layout from '../layouts/Layout.astro'
import { allImages } from '../data/images'
---

<Layout title="Forside">

  <div style="position: relative; min-height: 100vh; overflow: visible; display: flex; align-items: center; justify-content: center;">
    <img
      src="/images/waves_transperent.png"
      alt=""
      aria-hidden="true"
      style="position: absolute; left: 0; top: calc(20% + 100px); bottom: 0; width: auto; max-width: 50%; height: 80%; object-fit: contain; object-position: top left; opacity: 0.18; pointer-events: none; user-select: none; z-index: 0; mask-image: linear-gradient(to left, transparent 0%, black 40%); -webkit-mask-image: linear-gradient(to left, transparent 0%, black 40%);"
    />
    <!-- Hero logo -->
    <div style="position: relative; z-index: 60; display: inline-block; text-align: center; transform: translateY(-320px);">
      <img src="/images/logo.png" alt="" style="position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: contain; pointer-events: none; transform: translate(-50%, -65%) scale(0.7);" />
      <img src="/images/firstbloodtexttransparent.png" alt="First Blood Tattoo" style="position: relative; height: 40rem; width: auto; filter: drop-shadow(0 8px 40px rgba(0,0,0,0.9)); transform: translateY(-310px);" />
    </div>

    <img
      src="/images/trond.png"
      alt=""
      aria-hidden="true"
      style="position: absolute; right: 0; top: 0; height: 75%; width: auto; object-fit: contain; object-position: top right; opacity: 0.08; pointer-events: none; user-select: none; z-index: 1; mask-image: linear-gradient(to right, transparent 0%, black 40%), linear-gradient(to bottom, black 50%, transparent 100%); mask-composite: intersect; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 40%), linear-gradient(to bottom, black 50%, transparent 100%); -webkit-mask-composite: source-in;"
    />
  </div>

  <!-- Full-width gallery -->
  <div class="columns-2 md:columns-3 lg:columns-5 gap-1 space-y-1 w-full">
    {allImages.map(({ id, src, alt }) => (
      <div class="break-inside-avoid overflow-hidden cursor-pointer" onclick={`window.openLightbox('${id}')`}>
        <img src={src} alt={alt} class="w-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
      </div>
    ))}
  </div>

</Layout>
